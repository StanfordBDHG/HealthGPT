    "HEALTHKIT_PERMISSIONS_DESCRIPTION" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supported data types include sleep, step count, active energy, exercise minutes, heart rate, and body mass. \n\n HealthKit data is fetched on demand when you ask questions, and sent to OpenAI for processing. \n\n Please refer to the OpenAI privacy policy for more information."
          }
        }
      }
    },
    "HEALTHKIT_PERMISSIONS_SUBTITLE" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
